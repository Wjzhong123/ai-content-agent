# Content Scraper MCP Server Environment Variables
# 复制此文件为 .env 并填入实际值

# Reddit API 配置（可选）
# 从 https://www.reddit.com/prefs/apps 获取
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=ContentScraper/1.0 by YourUsername

# 输出配置
OUTPUT_DIR=/app/scraped_content

# 日志级别
LOG_LEVEL=INFO

# 代理配置（可选）
HTTP_PROXY=
HTTPS_PROXY=

# 时区设置
TZ=Asia/Shanghai